#!/bin/sh
# Maven Wrapper Script

set -e

MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"

# Determine JAVA_HOME if not set
if [ -z "$JAVA_HOME" ]; then
    JAVA_EXEC="java"
else
    JAVA_EXEC="$JAVA_HOME/bin/java"
fi

# If no wrapper jar, download Maven directly
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
    # Parse distribution URL from properties
    DIST_URL=$(grep distributionUrl "$MAVEN_WRAPPER_PROPERTIES" | cut -d= -f2-)
    MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.6"
    MAVEN_BIN="$MAVEN_HOME/apache-maven-3.9.6/bin/mvn"

    if [ ! -f "$MAVEN_BIN" ]; then
        echo "Downloading Maven 3.9.6..."
        mkdir -p "$MAVEN_HOME"
        curl -fsSL "$DIST_URL" -o "$MAVEN_HOME/maven.zip"
        unzip -q "$MAVEN_HOME/maven.zip" -d "$MAVEN_HOME"
        rm "$MAVEN_HOME/maven.zip"
        chmod +x "$MAVEN_BIN"
        echo "Maven downloaded successfully."
    fi

    exec "$MAVEN_BIN" "$@"
fi

exec "$JAVA_EXEC" -jar "$MAVEN_WRAPPER_JAR" "$@"
